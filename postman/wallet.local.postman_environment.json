{
  "id": "wallet-env-local",
  "name": "Wallet — Local",
  "values": [
    {
      "key": "base_url",
      "value": "http://localhost:8030",
      "type": "default",
      "enabled": true,
      "description": "Matches ADDR=:8030 in .env"
    },
    {
      "key": "username",
      "value": "alice",
      "type": "default",
      "enabled": true,
      "description": "Test username used in OTP requests"
    },
    {
      "key": "jwt_secret",
      "value": "REPLACE_ME",
      "type": "secret",
      "enabled": true,
      "description": "Must match JWT_SECRET in your .env — used by AuthMiddleware"
    },
    {
      "key": "jwt_secret_key",
      "value": "REPLACE_ME",
      "type": "secret",
      "enabled": true,
      "description": "Must match JWT_SECRET_KEY in your .env — used by VerifyOTP service"
    },
    {
      "key": "db_addr",
      "value": "postgres://root:password@localhost:5433/wallet?sslmode=disable",
      "type": "default",
      "enabled": true,
      "description": "Matches DB_ADDR in .env"
    },
    {
      "key": "auth_token",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Populated automatically by the Verify OTP test script"
    },
    {
      "key": "otp_code",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Populated automatically by the Request OTP test script"
    },
    {
      "key": "transaction_id",
      "value": "",
      "type": "default",
      "enabled": true,
      "description": "Populated automatically by the Create Transaction test script"
    },
    {
      "key": "receiver_id",
      "value": "2",
      "type": "default",
      "enabled": true,
      "description": "Target user ID for transaction and user-transactions lookup"
    }
  ],
  "_postman_variable_scope": "environment",
  "schema": "https://schema.getpostman.com/json/collection/v2.1.0/environment.json"
}
